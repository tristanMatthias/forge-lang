fn first<T>(list: List<T>) -> T? {
  if list.length > 0 { list[0] } else { null }
}

fn pair<A, B>(a: A, b: B) -> (A, B) {
  (a, b)
}

fn repeat<T: Clone>(item: T, n: int) -> List<T> {
  mut result: List<T> = []
  mut i = 0
  while i < n {
    result.push(item.clone())
    i = i + 1
  }
  result
}

fn main() {
  let nums = [10, 20, 30]
  let f = first(nums)
  println(string(f ?? 0))

  let strs = ["hello", "world"]
  let s = first(strs)
  println(s ?? "empty")

  let p = pair("age", 30)
  println(p.0)
  println(string(p.1))

  let fives = repeat(5, 3)
  println(string(fives.length))
  println(string(fives[0]))
}
