// Cross-feature test: Generics + Traits
// Tests generic functions with trait bounds

trait Describable {
  fn describe(self) -> string
}

type Cat = { name: string }
type Dog = { name: string }

impl Describable for Cat {
  fn describe(self) -> string {
    `cat: ${self.name}`
  }
}

impl Describable for Dog {
  fn describe(self) -> string {
    `dog: ${self.name}`
  }
}

fn greet<T: Describable>(animal: T) -> string {
  `hello, ${animal.describe()}`
}

fn main() {
  let c = Cat { name: "whiskers" }
  let d = Dog { name: "rex" }

  println(greet(c))
  println(greet(d))

  // Trait method directly
  println(c.describe())
  println(d.describe())
}
