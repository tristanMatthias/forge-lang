fn divide(a: float, b: float) -> Result<float, string> {
  if b == 0.0 {
    Err("division by zero")
  } else {
    Ok(a / b)
  }
}

fn calculate() -> Result<float, string> {
  let x = divide(10.0, 2.0)?
  let y = divide(x, 0.0)?
  Ok(y)
}

fn main() {
  let result = calculate() catch (e) {
    println(`error: ${e}`)
    0.0
  }
  println(string(result))
}
