/// The Forge CLI — written in Forge.
/// Declarative CLI definition with run handlers per command.

use @std.cli
use @std.process

mod shared
mod commands

use commands.{build, run, check, context, test, features, explain, version, why, lang, docs, package, errors, audit}

cli forge "The Forge programming language" {
    version "0.1.0"

    build
    run
    check
    context
    test
    features
    explain
    version
    why
    lang
    docs
    package
    errors
    audit
}
