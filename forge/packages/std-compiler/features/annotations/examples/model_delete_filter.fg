/// Test: Model.delete removes record, get returns null
///
/// expect: 3
/// expect: 2

use @std.model.{model}

model User {
  id: int @primary @auto_increment
  name: string
}

fn main() {
  User.create({ name: "alice" })
  User.create({ name: "bob" })
  User.create({ name: "charlie" })
  println(string(User.count()))

  User.delete(2)
  println(string(User.count()))
}
