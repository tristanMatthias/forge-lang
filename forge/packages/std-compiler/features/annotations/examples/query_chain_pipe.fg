/// Test: Query builder with step-by-step chaining
///
/// expect: 0

use @std.model.{model}

model Post {
    id: int @primary @auto_increment
    title: string
    status: string @default("draft")
}

fn main() {
    let q = Post.build_query()
    let q2 = Post.add_where(q, "{\"status\":\"published\"}")
    let q3 = Post.add_order(q2, "title", "asc")
    let q4 = Post.add_limit(q3, 10)
    let results = Post.exec_query(q4)
    println(string(results.length))
}
