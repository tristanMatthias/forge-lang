/// Struct with many fields (10+)
///
/// expect: a=1 b=2 c=3 d=4 e=5 f=6 g=7 h=8 i=9 j=10

type Big = {
  a: int, b: int, c: int, d: int, e: int,
  f: int, g: int, h: int, i: int, j: int
}

fn main() {
  let x = Big { a: 1, b: 2, c: 3, d: 4, e: 5, f: 6, g: 7, h: 8, i: 9, j: 10 }
  println(`a=${x.a} b=${x.b} c=${x.c} d=${x.d} e=${x.e} f=${x.f} g=${x.g} h=${x.h} i=${x.i} j=${x.j}`)
}
