/// # Wrong Method Call
///
/// Calling a nonexistent method on a struct with known methods produces a clear error.
///
/// expect-error: F0020

type Point = { x: int, y: int }

impl Point {
  fn distance(self) -> int {
    self.x + self.y
  }
}

fn main() {
  let p = Point { x: 1, y: 2 }
  println(string(p.distanc()))
}
