/// # Very Long Variable Names
///
/// The compiler handles arbitrarily long identifiers.
///
/// expect: 42

fn main() {
  let this_is_an_extremely_long_variable_name_that_goes_on_and_on_and_on_to_test_parser_limits = 42
  println(string(this_is_an_extremely_long_variable_name_that_goes_on_and_on_and_on_to_test_parser_limits))
}
