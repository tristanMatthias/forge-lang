/// # Nullable Chaining
///
/// Chain safe navigation with null coalescing.
///
/// expect: 5
/// expect: 0

fn find_user(id: int) -> string? {
  if id == 1 { "alice" } else { null }
}

fn main() {
  let len = find_user(1)?.length ?? 0
  println(string(len))

  let len2 = find_user(99)?.length ?? 0
  println(string(len2))
}
