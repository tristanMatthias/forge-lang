/// # Function Type in Struct Field
///
/// Store a function in a struct field using a function type.
///
/// expect: 10

fn apply(f: fn(int) -> int, x: int) -> int {
  f(x)
}

type Callback = { handler: fn(int) -> int }

fn main() {
  let cb = Callback { handler: (x: int) -> x * 2 }
  println(string(apply(cb.handler, 5)))
}
