/// # Recursive Enum - Simple
///
/// Self-referential enum with auto-boxing for recursive fields.
///
/// expect: 7

enum Expr {
  Lit(value: int)
  Add(left: Expr, right: Expr)
}

fn eval(e: Expr) -> int {
  match e {
    .Lit(v) -> v
    .Add(l, r) -> eval(l) + eval(r)
  }
}

fn main() {
  let e = Expr.Add(left: Expr.Lit(value: 3), right: Expr.Lit(value: 4))
  println(string(eval(e)))
}
