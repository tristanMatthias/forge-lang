/// # List Pop
///
/// Pop removes and returns the last element from a mutable list.
/// Returns null if the list is empty, so use ?? for a default.
///
/// expect: 30
/// expect: 20
/// expect: 1
/// expect: -1

fn main() {
  mut items = [10, 20, 30]
  let last = items.pop() ?? -1
  println(string(last))

  let second = items.pop() ?? -1
  println(string(second))

  println(string(items.length))

  items.pop()
  let empty_pop = items.pop() ?? -1
  println(string(empty_pop))
}
