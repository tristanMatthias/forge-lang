/// # For Range with Break
///
/// Break out of a range for loop early using loop { break }.
/// Since break in range-for is limited, use a loop with manual index.
///
/// expect: 0
/// expect: 1
/// expect: 2
/// expect: done

fn main() {
  mut i = 0
  loop {
    if i >= 10 {
      break
    }
    if i == 3 {
      break
    }
    println(i)
    i = i + 1
  }
  println("done")
}
