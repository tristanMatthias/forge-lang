/// # Nested Pattern: Constant Folding
///
/// Nested enum patterns to fold `Add(Lit(a), Lit(b))` into `Lit(a + b)`.
///
/// expect: 7

enum Expr {
  Lit(value: int)
  Add(left: Expr, right: Expr)
}

fn eval(e: Expr) -> int {
  match e {
    .Lit(v) -> v
    .Add(.Lit(a), .Lit(b)) -> a + b
    _ -> 0
  }
}

fn main() {
  let e = Expr.Add(left: Expr.Lit(value: 3), right: Expr.Lit(value: 4))
  println(string(eval(e)))
}
