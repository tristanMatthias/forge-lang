/// # Dynamic Dispatch
///
/// Trait name as type — call a trait method via vtable on a concrete type.
///
/// expect: hello

type Greeter = { name: string }

trait Greet {
  fn greet() -> string
}

impl Greet for Greeter {
  fn greet() -> string {
    "hello"
  }
}

fn main() {
  let g = Greeter { name: "world" }
  let d: Greet = g
  println(d.greet())
}
