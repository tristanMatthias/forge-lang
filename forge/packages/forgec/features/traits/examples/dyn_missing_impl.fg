/// # Missing Trait Impl Error
///
/// Assigning a type that doesn't implement a trait
/// should produce a clear type error.
///
/// expect-error: F0012

type Dog = { name: string }

trait Flyable {
  fn fly() -> string
}

fn main() {
  let d = Dog { name: "Rex" }
  let f: Flyable = d
  println(f.fly())
}
