/// # Trait as Function Argument
///
/// Pass a trait-typed value to a function and call its methods.
///
/// expect: area: 50

type Rect = { w: int, h: int }

trait Shape {
  fn area() -> int
}

impl Shape for Rect {
  fn area() -> int {
    self.w * self.h
  }
}

fn print_area(s: Shape) {
  println("area: ${string(s.area())}")
}

fn main() {
  let r = Rect { w: 5, h: 10 }
  print_area(r)
}
