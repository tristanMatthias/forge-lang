/// Test: Model after_create hook runs after record is inserted
///
/// expect: created: alice
/// expect: 1

use @std.model.{model}

model User {
  id: int @primary @auto_increment
  name: string

  on after_create(user) {
    println("created: " + user.name)
  }
}

fn main() {
  let id = User.create({ name: "alice" })
  println(string(id))
}
