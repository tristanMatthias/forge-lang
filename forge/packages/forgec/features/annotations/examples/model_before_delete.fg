/// Test: before_delete hook runs before delete
///
/// expect: deleting id 1
/// expect: 0

use @std.model.{model}

model User {
  id: int @primary @auto_increment
  name: string
  role: string

  on before_delete(id: int) {
    println("deleting id " + string(id))
  }
}

fn main() {
  let id = User.create({ name: "alice", role: "admin" })
  User.delete(id)
  println(string(User.count()))
}
