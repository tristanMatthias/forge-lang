/// Test: Model.insert_batch — bulk insert records
///
/// expect: 3
/// expect: 3

use @std.model.{model}

model Item {
  id: int @primary @auto_increment
  name: string
  category: string
}

fn main() {
  let inserted = Item.insert_batch("[{\"name\":\"a\",\"category\":\"x\"},{\"name\":\"b\",\"category\":\"y\"},{\"name\":\"c\",\"category\":\"x\"}]")
  println(string(inserted))
  println(string(Item.count()))
}
