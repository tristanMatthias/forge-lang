/// expect-check: pass
/// Verifies middleware inside scoped under blocks compiles correctly

use @std.http.{server}

server :8080 {
  use_middleware "global_logger" (req_ptr) -> {
    0
  }

  under "/api"
  use_middleware "api_auth" (req_ptr) -> {
    0
  }
  route GET /users -> { "[]" }
  route GET /health -> { "ok" }
  end under

  route GET / -> { "welcome" }
}
