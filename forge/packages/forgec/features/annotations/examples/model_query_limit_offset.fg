/// Test: Model.query with limit and offset for pagination
///
/// expect: bob
/// expect: charlie

use @std.model.{model}

model User {
  id: int @primary @auto_increment
  name: string
}

fn main() {
  User.create({ name: "alice" })
  User.create({ name: "bob" })
  User.create({ name: "charlie" })
  User.create({ name: "dave" })

  let page2 = User.query({ order: "id ASC", limit: 2, offset: 1 })
  println(page2[0].name)
  println(page2[1].name)
}
