/// # ptr to string conversion
/// expect: Hello
/// expect: 5
extern fn malloc(size: int) -> ptr
extern fn free(p: ptr)

fn main() {
  let buf = malloc(16)
  defer free(buf)

  buf[0] = 72
  buf[1] = 101
  buf[2] = 108
  buf[3] = 108
  buf[4] = 111

  let s = string.from_ptr(buf, 5)
  println(s)
  println(string(s.length()))
}
