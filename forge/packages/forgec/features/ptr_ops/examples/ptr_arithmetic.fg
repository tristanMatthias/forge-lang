/// # Pointer arithmetic
/// expect: 66
/// expect: 67
/// expect: 67
extern fn malloc(size: int) -> ptr
extern fn free(p: ptr)

fn main() {
  let buf = malloc(16)
  defer free(buf)

  buf[0] = 65
  buf[1] = 66
  buf[2] = 67

  let second = buf + 1
  println(string(second[0]))
  println(string(second[1]))

  let third = buf + 2
  println(string(third[0]))
}
