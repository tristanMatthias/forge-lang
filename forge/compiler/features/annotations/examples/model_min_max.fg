/// Test: Model.min and Model.max aggregates
///
/// expect: 5.0
/// expect: 200.0

use @std.model.{model}

model Product {
  id: int @primary @auto_increment
  name: string
  price: int
}

fn main() {
  Product.create({ name: "cheap", price: 5 })
  Product.create({ name: "medium", price: 50 })
  Product.create({ name: "expensive", price: 200 })

  println(string(Product.min("price")))
  println(string(Product.max("price")))
}
