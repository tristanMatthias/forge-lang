/// Test: Model-level annotation @table parses without error
/// Model-level annotations are stored on the component block.
///
/// expect: Hello
/// expect: 1

use @std.model.{model}

model Post {
  @table("blog_posts")
  id: int @primary @auto_increment
  title: string
}

fn main() {
  Post.create({ title: "Hello" })
  let post = Post.get(1)
  if post != null {
    println(post.title)
  }
  println(string(Post.count()))
}
