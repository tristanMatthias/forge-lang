/// Test: Model.exists — check record existence
///
/// expect: 0
/// expect: 1

use @std.model.{model}

model User {
  id: int @primary @auto_increment
  name: string
}

fn main() {
  println(string(User.exists({ name: "alice" })))
  User.create({ name: "alice" })
  println(string(User.exists({ name: "alice" })))
}
