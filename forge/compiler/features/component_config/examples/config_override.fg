/// # Component Config Override
///
/// User-specified config overrides the schema default.
/// Config schema: `every: int = 1000`. User sets `every 100`.
///
/// expect: fast
/// expect: fast
/// expect: fast
/// expect: done

use @std.cron.{schedule}

schedule fast_ticker {
  every 100
  run { println("fast") }
}

fn main() {
  fast_ticker.start()
  forge_sleep(350)
  fast_ticker.stop()
  println("done")
}
