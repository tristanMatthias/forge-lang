/// # Zero to Zero Range
///
/// Adversarial test: 0..0 should be empty, 0..=0 should have one element.
///
/// expect: exclusive 0..0: 0
/// expect: inclusive 0..=0: 1

fn main() {
  mut count = 0
  for i in 0..0 {
    count = count + 1
  }
  println(`exclusive 0..0: ${count}`)

  mut count2 = 0
  for i in 0..=0 {
    count2 = count2 + 1
  }
  println(`inclusive 0..=0: ${count2}`)
}
