/// # Parallel Spawn
///
/// Spawn concurrent tasks that communicate via channels.
///
/// expect: a
/// expect: b

use @std.channel

fn main() {
  let ch = channel(10)

  spawn {
    sleep(10)
    ch <- "a"
  }
  spawn {
    sleep(50)
    ch <- "b"
  }

  let msg1 = <- ch
  let msg2 = <- ch
  println(msg1)
  println(msg2)
}
