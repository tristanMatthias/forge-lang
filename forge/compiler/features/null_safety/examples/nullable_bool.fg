/// # Nullable Bool
///
/// Functions returning `bool?` with null coalescing.
///
/// expect: true
/// expect: false

fn maybe_bool(x: int) -> bool? {
  if x > 0 { true } else { null }
}

fn main() {
  let a = maybe_bool(1) ?? false
  println(string(a))

  let b = maybe_bool(-1) ?? false
  println(string(b))
}
