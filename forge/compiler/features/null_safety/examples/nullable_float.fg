/// # Nullable Float
///
/// Functions returning `float?` with null coalescing.
///
/// expect: 3.14
/// expect: 0.0

fn maybe_float(x: bool) -> float? {
  if x { 3.14 } else { null }
}

fn main() {
  let a = maybe_float(true) ?? 0.0
  println(string(a))

  let b = maybe_float(false) ?? 0.0
  println(string(b))
}
