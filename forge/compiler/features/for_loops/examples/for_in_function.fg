/// # For Loop in Function
///
/// Test for loops inside functions with variable range bounds.
/// Also tests empty range (start > end) and zero-length range.
///
/// expect: 55
/// expect: 0
/// expect: 0

fn sum_range(start: int, end: int) -> int {
  mut total = 0
  for i in start..end {
    total = total + i
  }
  total
}

fn main() {
  println(sum_range(1, 11))
  println(sum_range(0, 0))
  println(sum_range(5, 3))
}
