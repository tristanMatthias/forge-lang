/// Trait bound violation: calling generic fn with type that doesn't implement the trait
///
/// expect-error: F0012

trait Describable {
  fn describe(self) -> string
}

type Dog = { name: string }

fn describe_item<T: Describable>(item: T) -> string {
  item.describe()
}

fn main() {
  let d = Dog { name: "Rex" }
  println(describe_item(d))
}
