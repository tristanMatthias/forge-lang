/// # Nested While Loops
///
/// Two nested while loops multiplying indices.
///
/// expect: 0,0
/// expect: 0,1
/// expect: 1,0
/// expect: 1,1
/// expect: 2,0
/// expect: 2,1

fn main() {
  mut i = 0
  while i < 3 {
    mut j = 0
    while j < 2 {
      println(`${i},${j}`)
      j = j + 1
    }
    i = i + 1
  }
}
